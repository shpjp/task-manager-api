# PostgreSQL connection (docker-compose maps the container to host port 5433)
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=taskmanager

# HTTP port the API listens on
APP_PORT=8080

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=

# JWT lifetime in hours (default 24)
TOKEN_TTL_HOURS=24

# Origin allowed by CORS (the Next.js frontend)
FRONTEND_ORIGIN=http://localhost:3000

# Set to "true" when serving over HTTPS so auth cookies are Secure
COOKIE_SECURE=false

# Comma-separated emails that get the admin role at signup/login (optional)
ADMIN_EMAILS=

# Directory where task attachments are stored
UPLOAD_DIR=./uploads

# Maximum attachment size in megabytes
MAX_UPLOAD_MB=5
